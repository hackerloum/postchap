# Firebase Client (for browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (for API routes)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=

# Poster generation
OPENAI_API_KEY=
FREEPIK_API_KEY=
GEMINI_API_KEY=
# USE_FREEPIK_IMPROVE_PROMPT=true  # When set, runs Freepik prompt enhancement by default (user can override in UI)
NEXT_PUBLIC_APP_URL=

# Cloudinary (image storage — replaces Firebase Storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Snippe (payments — Pro/Business checkout)
SNIPPE_API_KEY=
SNIPPE_WEBHOOK_SECRET=

# Meta / Instagram (social posting)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=https://artmasterpro.com/api/social/callback/instagram

# Admin VPS terminal (superadmin only; WebSocket server runs separately)
TERMINAL_JWT_SECRET=
TERMINAL_WS_PORT=3001
VPS_HOST=
VPS_PORT=22
VPS_USERNAME=
VPS_PASSWORD=
# Or base64-encoded PEM private key (no password):
# VPS_PRIVATE_KEY=
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_VPS_HOST_LABEL=eVPS Server
